{
  "design_philosophy": "Create OUR OWN professional CBT interface using Ultimate Exam Arena brand colors (#050a1c dark navy, #1d4ed8 blue) while maintaining JAMB exam standards",
  
  "jamb_standards_compliance": {
    "total_questions": 180,
    "exam_duration": "180 minutes",
    "subject_breakdown": "60 English + 40 + 40 + 40 (3 other subjects)",
    "timer_format": "HH:MM:SS countdown",
    "question_format": "Multiple choice (A/B/C/D)",
    "navigation": "Question palette showing all 180 questions",
    "features": ["Auto-save", "Flag questions", "Calculator", "Question review", "Keyboard shortcuts"]
  },

  "exam_interface_layout": {
    "header": {
      "background_color": "#1d4ed8",
      "text_color": "#e9f2ff",
      "height": "60px",
      "position": "sticky-top",
      "elements": [
        {
          "position": "left",
          "content": "Ultimate Exam Arena Logo",
          "size": "32px",
          "icon": "book-shield-blue"
        },
        {
          "position": "center",
          "content": "Current Subject Name",
          "size": "18px",
          "font_weight": "600",
          "example": "Mathematics"
        },
        {
          "position": "right",
          "element": "timer",
          "format": "MM:MM:SS",
          "color_logic": {
            "green": "> 10 minutes",
            "amber": "5-10 minutes",
            "red_pulsing": "< 5 minutes"
          }
        },
        {
          "position": "right",
          "element": "quit_button",
          "label": "[Quit Exam]",
          "background": "#f87171",
          "color": "white",
          "margin_left": "12px"
        }
      ]
    },

    "main_content": {
      "layout": "flex",
      "display": "sidebar + center + (optional navigator below)",
      
      "question_area": {
        "position": "center",
        "background": "#050a1c",
        "padding": "24px",
        "width": "60-70%",
        
        "question_header": {
          "text": "Question X of 180",
          "color": "#9bb3d6",
          "font_size": "14px",
          "margin_bottom": "12px",
          "progress_bar": {
            "height": "4px",
            "background": "#0c1630",
            "fill": "#1d4ed8",
            "percent_complete": "calculated"
          }
        },

        "question_text": {
          "font_size": "18px",
          "line_height": "1.6",
          "color": "#e9f2ff",
          "margin_bottom": "24px",
          "font_family": "Inter or Plus Jakarta Sans"
        },

        "options_container": {
          "display": "grid",
          "gap": "12px",
          "options": [
            {
              "letter": "A",
              "text": "Option A text here",
              "background": "#0c1630",
              "border": "1px solid rgba(255,255,255,0.08)",
              "border_radius": "8px",
              "padding": "12px 16px",
              "cursor": "pointer",
              "hover": {
                "background": "#101d35",
                "border_color": "rgba(255,255,255,0.15)"
              },
              "selected": {
                "background": "#1d4ed8",
                "border_color": "#2563eb",
                "color": "white"
              }
            }
          ]
        },

        "controls": {
          "display": "flex",
          "gap": "12px",
          "margin_top": "24px",
          "justify_content": "space-between",
          
          "buttons": [
            {
              "id": "prev_btn",
              "label": "[◀ Previous]",
              "disabled_on": "question_1",
              "background": "#0c1630",
              "text_color": "#e9f2ff"
            },
            {
              "id": "flag_btn",
              "label": "[🚩 Flag]",
              "toggles": true,
              "active_color": "#f59e0b",
              "inactive_color": "#0c1630"
            },
            {
              "id": "next_btn",
              "label": "[Next ▶]",
              "background": "#1d4ed8",
              "text_color": "white",
              "on_last_question": "becomes_submit"
            }
          ]
        }
      },

      "right_sidebar": {
        "position": "right",
        "width": "25%",
        "background": "#0c1630",
        "border_left": "1px solid rgba(255,255,255,0.08)",
        "padding": "16px",
        
        "header": {
          "text": "Question Navigator",
          "font_size": "12px",
          "color": "#9bb3d6",
          "text_transform": "uppercase",
          "margin_bottom": "12px"
        },

        "question_grid": {
          "display": "grid",
          "grid_template_columns": "repeat(6, 1fr)",
          "gap": "6px",
          "max_height": "400px",
          "overflow_y": "auto",

          "question_number_box": {
            "width": "28px",
            "height": "28px",
            "display": "flex",
            "align_items": "center",
            "justify_content": "center",
            "border_radius": "4px",
            "font_size": "11px",
            "cursor": "pointer",
            "border": "1px solid",
            
            "status_colors": {
              "answered": {
                "background": "#10b981",
                "border_color": "#059669",
                "color": "white"
              },
              "flagged": {
                "background": "#f59e0b",
                "border_color": "#d97706",
                "color": "white"
              },
              "unanswered": {
                "background": "#101d35",
                "border_color": "rgba(255,255,255,0.08)",
                "color": "#9bb3d6"
              },
              "current": {
                "border": "2px solid #1d4ed8",
                "box_shadow": "0 0 8px rgba(29,78,216,0.3)"
              }
            }
          }
        },

        "summary": {
          "margin_top": "16px",
          "padding_top": "16px",
          "border_top": "1px solid rgba(255,255,255,0.08)",
          "font_size": "12px",
          "color": "#9bb3d6",
          
          "items": [
            {
              "label": "Answered",
              "value": "X",
              "icon": "✓ (green)"
            },
            {
              "label": "Flagged",
              "value": "X",
              "icon": "🚩 (orange)"
            },
            {
              "label": "Unanswered",
              "value": "X",
              "icon": "◯ (grey)"
            }
          ]
        }
      }
    },

    "calculator": {
      "type": "floating_overlay",
      "position": "bottom-right",
      "background": "#0c1630",
      "border": "1px solid rgba(255,255,255,0.08)",
      "border_radius": "8px",
      "width": "280px",
      "z_index": "1000",
      
      "header": {
        "text": "Calculator",
        "button_minimize": "-",
        "button_close": "×",
        "drag_handle": true
      },

      "display": {
        "height": "50px",
        "background": "#050a1c",
        "text_align": "right",
        "font_size": "18px",
        "color": "#e9f2ff",
        "padding": "8px"
      },

      "buttons_grid": {
        "display": "grid",
        "grid_template_columns": "repeat(4, 1fr)",
        "gap": "4px",
        "padding": "8px",
        
        "button_groups": {
          "numbers": ["0-9"],
          "operations": ["+", "-", "×", "÷"],
          "functions": ["√", "%", "=", "C"]
        }
      }
    }
  },

  "color_scheme": {
    "primary": "#050a1c",
    "surface": "#0c1630",
    "surface_muted": "#101d35",
    "accent": "#1d4ed8",
    "accent_hover": "#2563eb",
    "text_primary": "#e9f2ff",
    "text_muted": "#9bb3d6",
    "success": "#10b981",
    "warning": "#f59e0b",
    "danger": "#f87171",
    "border": "rgba(255,255,255,0.08)"
  },

  "keyboard_shortcuts": {
    "A": "Select option A",
    "B": "Select option B",
    "C": "Select option C",
    "D": "Select option D",
    "N": "Next question",
    "P": "Previous question",
    "F": "Flag/unflag question",
    "S": "Submit exam (with confirmation)",
    "SPACE": "Toggle calculator"
  },

  "responsive_design": {
    "desktop": {
      "breakpoint": "> 1024px",
      "layout": "3-column (sidebar + center + navigator)",
      "question_area_width": "60%",
      "navigator_width": "25%"
    },
    "tablet": {
      "breakpoint": "768px - 1024px",
      "layout": "2-column (center + navigator)",
      "navigator": "right sidebar, collapsible",
      "question_area_width": "70%"
    },
    "mobile": {
      "breakpoint": "< 768px",
      "layout": "single-column",
      "navigator": "bottom tab or modal popup",
      "question_area": "full width",
      "header": "condensed",
      "controls": "full width buttons"
    }
  },

  "exam_flow": {
    "before_exam": "Show exam setup page with subject selection, time, instructions",
    "during_exam": "Full-screen exam interface with timer, questions, calculator",
    "after_exam": "Results page with JAMB grading, university recommendations",
    "features": {
      "auto_save": "Save answers every 30 seconds",
      "tab_switch_warning": "Alert if student leaves exam tab",
      "copy_paste_disabled": "Prevent cheating during exam",
      "fullscreen_option": "Optional fullscreen mode"
    }
  },

  "design_implementation_notes": {
    "note_1": "Our colors (#050a1c + #1d4ed8) create professional JAMB-like interface WITHOUT copying official design",
    "note_2": "Question palette (1-180 grid) provides visual progress tracking like real JAMB CBT",
    "note_3": "Sticky header ensures timer always visible",
    "note_4": "Responsive design works on all devices (desktop, tablet, mobile)",
    "note_5": "Calculator overlay stays accessible without blocking question view",
    "note_6": "All buttons use consistent sizing (28-32px) and spacing (8-12px gaps)"
  }
}
